{
  "name": "server",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "nx build server",
    "package:sea:enhanced": "pkg --sea .",
    "package:sea": "pkg apps/server/dist/main.js -t node22-linux-x64,node22-macos-arm64,node22-win-x64 --sea -o dist/sea/server",
    "package": "pkg apps/server/dist/main.js -t node22-linux-x64,node22-macos-arm64,node22-win-x64 -o dist/pkg/server"
  },
  "private": true,
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@yao-pkg/pkg": "^6.15.0",
    "axios": "^1.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/nest": "22.6.5",
    "@nx/node": "22.6.5",
    "@nx/web": "22.6.5",
    "@nx/webpack": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "nx": "22.6.5",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*"
  ],
  "bin": "apps/server/dist/main.js",
  "pkg": {
    "targets": [
      "node22-linux-x64",
      "node22-macos-arm64",
      "node22-win-x64"
    ],
    "outputPath": "dist/sea-enhanced"
  }
}
